{
  "name": "cine-tube-server",
  "version": "1.0.0",
  "description": "Movie and Series Rating & Streaming Portal Backend",
  "main": "index.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "prisma generate",
    "build:tsup" : "tsup",
    "build:server": "prisma generate && tsup src/server.ts --format esm --platform node --target node20 --outDir api",
    "postinstall": "prisma generate && pnpm run build:vercel",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint ./src/**/*",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "studio": "prisma studio",
    "push": "prisma db push",
    "pull": "prisma db pull",
    "stripe:webhook": "stripe listen --forward-to 127.0.0.1:5000/webhook",
    "build:vercel": "prisma generate && tsup --config tsup.config.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "movie",
    "series",
    "rating",
    "streaming",
    "portal"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.6.0",
    "@stripe/stripe-js": "^8.11.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.18",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "http-status": "^2.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.2",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.18.0",
    "slugify": "^1.6.6",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/nodemailer": "^7.0.11",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.2.0",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.2",
    "prisma": "^7.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
