<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: Arial, sans-serif; background: #f5f5f5; padding: 20px; }
    .container { max-width: 600px; margin: 0 auto; background: white; padding: 30px; border-radius: 8px; }
    .header { text-align: center; margin-bottom: 30px; }
    .logo { font-size: 28px; font-weight: bold; color: #e50914; }
    .otp-box { background: #f0f0f0; padding: 20px; text-align: center; font-size: 32px; letter-spacing: 8px; font-weight: bold; margin: 20px 0; }
    .message { color: #666; line-height: 1.6; }
    .footer { text-align: center; margin-top: 30px; color: #999; font-size: 12px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo">🎬 CineTube</div>
    </div>
    <h2>Verify Your Email</h2>
    <p class="message">Hi <%= userName %>,</p>
    <p class="message">Use the following OTP to verify your email address. This code will expire in 10 minutes.</p>
    <div class="otp-box"><%= otp %></div>
    <p class="message">If you didn't request this, please ignore this email.</p>
    <div class="footer">
      <p>© <%= year %> CineTube. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
