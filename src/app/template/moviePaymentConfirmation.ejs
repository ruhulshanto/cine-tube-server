<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: Arial, sans-serif; background: #f5f5f5; padding: 20px; }
    .container { max-width: 600px; margin: 0 auto; background: white; padding: 30px; border-radius: 8px; }
    .header { text-align: center; margin-bottom: 24px; }
    .logo { font-size: 28px; font-weight: bold; color: #e50914; }
    .receipt-box { background: #f9f9f9; padding: 20px; border-radius: 4px; margin: 20px 0; }
    .row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px dashed #ddd; }
    .row:last-child { border-bottom: none; }
    .button { display: inline-block; background: #e50914; color: white; padding: 12px 30px; text-decoration: none; border-radius: 4px; margin: 20px 0; }
    .message { color: #666; line-height: 1.6; }
    .footer { text-align: center; margin-top: 30px; color: #999; font-size: 12px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo">🎬 CineTube</div>
      <h2>Payment confirmed</h2>
    </div>
    <p class="message">Hi <%= firstName %>,</p>
    <p class="message">Thanks — your <strong><%= paymentTypeLabel %></strong> for <strong><%= movieTitle %></strong> is complete. You can start watching from the movie page while signed in.</p>

    <div class="receipt-box">
      <div class="row">
        <span>Title</span>
        <span><%= movieTitle %></span>
      </div>
      <div class="row">
        <span>Type</span>
        <span><%= paymentTypeLabel %></span>
      </div>
      <div class="row">
        <span>Amount</span>
        <span><%= amount %> <%= currency %></span>
      </div>
      <div class="row">
        <span>Reference</span>
        <span style="font-size:12px;word-break:break-all;"><%= transactionId %></span>
      </div>
      <div class="row">
        <span>Date</span>
        <span><%= date %></span>
      </div>
    </div>

    <div style="text-align: center;">
      <a href="<%= watchUrl %>" class="button">Browse catalog</a>
    </div>

    <div class="footer">
      <p>© <%= year %> CineTube. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
